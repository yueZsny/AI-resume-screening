# Server
PORT=3000

# CORS（生产环境在 Vercel Dashboard 配置）
ALLOWED_ORIGINS=

# Database (MySQL) — 若仍使用 MySQL 业务层
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=resume_screening
DATABASE_URL=mysql://root:password@localhost:3306/resume_screening

# Turso / libsql（Drizzle：src/db/index.ts）
# 在 https://turso.tech 创建数据库后，复制 Connection URL 与「Create Token」生成的 JWT
TURSO_DATABASE_URL=libsql://your-db-name-xxxxx.aws-region.turso.io
TURSO_AUTH_TOKEN=

# JWT（应用登录，与 Turso Token 无关）
JWT_SECRET=
JWT_EXPIRES_IN=7d
REFRESH_EXPIRES_IN=30d

ENCRYPTION_KEY=
