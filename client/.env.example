# Vercel 部署环境变量
# ⚠️ 重要：请将 your-server.vercel.app 替换为实际的后端部署地址！

# API 基础 URL（本地开发使用 localhost，Vercel 部署时使用实际后端地址）
VITE_API_BASE_URL=https://your-server.vercel.app

# 如果前后端分开部署，设置后端 API 地址
# ⚠️ 必须配置！否则前端无法请求后端 API
VITE_SERVER_URL=https://your-server.vercel.app

# 前端域名（用于后端 CORS 配置，用逗号分隔多个域名）
VITE_CLIENT_URL=https://ai-resume-screening-mncb.vercel.app
